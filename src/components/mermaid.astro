---
interface Props {
  chart: string
}

const { chart } = Astro.props
---

<div class="mermaid" set:text={chart} />

<script>
  import mermaid from 'mermaid'

  let nextId = 0

  function getTheme() {
    return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'default'
  }

  function initializeMermaid() {
    mermaid.initialize({
      startOnLoad: false,
      theme: getTheme(),
    })
  }

  initializeMermaid()

  async function renderElement(element) {
    const container = element
    const chart = container.__chart ?? container.textContent ?? ''

    if (!chart.trim()) {
      return
    }

    container.__chart = chart

    const { svg, bindFunctions } = await mermaid.render(`mermaid-${nextId++}`, chart)
    container.innerHTML = svg
    bindFunctions?.(container)
  }

  async function renderMermaid() {
    const elements = document.querySelectorAll('.mermaid')
    if (elements.length === 0) {
      return
    }

    for (const element of elements) {
      await renderElement(element)
    }
  }

  renderMermaid()

  // Re-render on theme change
  const observer = new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      if (mutation.attributeName === 'data-theme') {
        initializeMermaid()
        renderMermaid()
      }
    }
  })

  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] })
</script>

<style>
  .mermaid {
    background: transparent;
    border: none;
    text-align: center;
  }
</style>
